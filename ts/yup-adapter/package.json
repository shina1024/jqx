{
  "name": "@shina1024/jqx-yup-adapter",
  "version": "0.1.1",
  "description": "Yup adapter for jqx, a jq-compatible JSON processor written in MoonBit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shina1024/jqx.git",
    "directory": "ts/yup-adapter"
  },
  "homepage": "https://github.com/shina1024/jqx/tree/main/ts/yup-adapter",
  "bugs": {
    "url": "https://github.com/shina1024/jqx/issues"
  },
  "keywords": [
    "jq",
    "typescript",
    "yup",
    "schema",
    "adapter"
  ],
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/ts_package_build.mjs src/index.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:typeaware": "oxlint . --type-aware --type-check",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "pnpm build && node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@shina1024/jqx-adapter-core": "workspace:^"
  },
  "devDependencies": {
    "@typescript/native-preview": "beta",
    "@types/node": "^25.6.0",
    "expect-type": "^1.3.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsdown": "0.22.0",
    "tsx": "^4.21.0",
    "yup": "^1.7.1"
  },
  "peerDependencies": {
    "yup": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "yup": {
      "optional": true
    }
  }
}
