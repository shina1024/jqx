{
  "name": "@shina1024/jqx-valibot-adapter",
  "version": "0.1.0",
  "description": "Valibot adapter utilities for jqx JS/TS runtime",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@shina1024/jqx-adapter-core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "expect-type": "^1.3.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.50.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "valibot": "^1.1.0"
  },
  "peerDependencies": {
    "valibot": "^1.0.0"
  },
  "pnpm": {
    "overrides": {
      "@shina1024/jqx-adapter-core": "file:../adapter-core"
    }
  }
}
