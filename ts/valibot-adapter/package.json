{
  "name": "@shina1024/jqx-valibot-adapter",
  "version": "0.1.0",
  "description": "Valibot adapter utilities for jqx JS/TS runtime",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shina1024/jqx.git",
    "directory": "ts/valibot-adapter"
  },
  "homepage": "https://github.com/shina1024/jqx/tree/main/ts/valibot-adapter",
  "bugs": {
    "url": "https://github.com/shina1024/jqx/issues"
  },
  "keywords": [
    "jq",
    "typescript",
    "valibot",
    "schema",
    "adapter"
  ],
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/ts_package_build.mjs src/index.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:typeaware": "oxlint . --type-aware --type-check",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@shina1024/jqx-adapter-core": "^0.1.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260313.1",
    "@types/node": "^25.4.0",
    "rolldown": "1.0.0-rc.9",
    "expect-type": "^1.3.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.54.0",
    "oxlint-tsgolint": "^0.17.0",
    "tsx": "^4.21.0",
    "valibot": "^1.2.0"
  },
  "peerDependencies": {
    "valibot": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "valibot": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "@shina1024/jqx-adapter-core": "file:../adapter-core"
    }
  }
}
