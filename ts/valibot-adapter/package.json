{
  "name": "@shina1024/jqx-valibot-adapter",
  "version": "0.3.0",
  "description": "Valibot adapter for jqx, a jq-compatible JSON processor written in MoonBit",
  "keywords": [
    "adapter",
    "jq",
    "schema",
    "typescript",
    "valibot"
  ],
  "homepage": "https://github.com/shina1024/jqx/tree/main/ts/valibot-adapter",
  "bugs": {
    "url": "https://github.com/shina1024/jqx/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shina1024/jqx.git",
    "directory": "ts/valibot-adapter"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "format": "vp fmt .",
    "format:check": "vp fmt . --check",
    "lint": "vp lint .",
    "lint:typeaware": "vp lint . --type-aware --type-check",
    "lint:fix": "vp lint . --fix",
    "typecheck": "vp lint . --type-aware --type-check",
    "test": "pnpm build && vp test"
  },
  "dependencies": {
    "@shina1024/jqx-adapter-core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "valibot": "^1.4.2"
  },
  "peerDependencies": {
    "valibot": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "valibot": {
      "optional": true
    }
  }
}
