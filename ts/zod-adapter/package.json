{
  "name": "@shina1024/jqx-zod-adapter",
  "version": "0.1.0",
  "description": "Zod adapter utilities for jqx JS/TS runtime",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shina1024/jqx.git",
    "directory": "ts/zod-adapter"
  },
  "homepage": "https://github.com/shina1024/jqx/tree/main/ts/zod-adapter",
  "bugs": {
    "url": "https://github.com/shina1024/jqx/issues"
  },
  "keywords": [
    "jq",
    "typescript",
    "zod",
    "schema",
    "adapter"
  ],
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@shina1024/jqx-adapter-core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "expect-type": "^1.3.0",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.54.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "@shina1024/jqx-adapter-core": "file:../adapter-core"
    }
  }
}
