{
  "name": "@shina1024/jqx-zod-adapter",
  "version": "0.1.0",
  "description": "Zod adapter utilities for jqx JS/TS runtime",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shina1024/jqx.git",
    "directory": "ts/zod-adapter"
  },
  "homepage": "https://github.com/shina1024/jqx/tree/main/ts/zod-adapter",
  "bugs": {
    "url": "https://github.com/shina1024/jqx/issues"
  },
  "keywords": [
    "jq",
    "typescript",
    "zod",
    "schema",
    "adapter"
  ],
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/ts_package_build.mjs src/index.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:typeaware": "oxlint . --type-aware --type-check",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "pnpm build && node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@shina1024/jqx-adapter-core": "^0.1.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260319.1",
    "@types/node": "^25.5.0",
    "expect-type": "^1.3.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.0",
    "tsdown": "0.21.5",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "@shina1024/jqx-adapter-core": "file:../adapter-core"
    }
  }
}
