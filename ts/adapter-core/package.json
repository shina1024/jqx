{
  "name": "@shina1024/jqx-adapter-core",
  "version": "0.1.0",
  "description": "Shared runtime and inference utilities for jqx TS adapters",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shina1024/jqx.git",
    "directory": "ts/adapter-core"
  },
  "homepage": "https://github.com/shina1024/jqx/tree/main/ts/adapter-core",
  "bugs": {
    "url": "https://github.com/shina1024/jqx/issues"
  },
  "keywords": [
    "jq",
    "typescript",
    "adapter",
    "runtime",
    "schema"
  ],
  "license": "Apache-2.0",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/ts_package_build.mjs src/index.ts",
    "prepare": "pnpm build",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:typeaware": "oxlint . --type-aware --type-check",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260416.1",
    "expect-type": "^1.3.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "tsdown": "0.21.8"
  }
}
