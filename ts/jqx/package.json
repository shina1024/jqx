{
  "name": "@shina1024/jqx",
  "version": "0.2.0",
  "description": "JavaScript and TypeScript bindings for jqx, a jq-compatible JSON processor written in MoonBit",
  "keywords": [
    "filter",
    "jq",
    "json",
    "query",
    "schema",
    "typescript"
  ],
  "homepage": "https://github.com/shina1024/jqx/tree/main/ts/jqx",
  "bugs": {
    "url": "https://github.com/shina1024/jqx/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shina1024/jqx.git",
    "directory": "ts/jqx"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bind": {
      "types": "./dist/bind.d.ts",
      "import": "./dist/bind.js",
      "require": "./dist/bind.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:moon-runtime": "node ../../scripts/moon_exec.mjs -C ../.. build --target js --release js",
    "build": "pnpm build:moon-runtime && vp pack",
    "format": "vp fmt .",
    "format:check": "vp fmt . --check",
    "lint": "vp lint .",
    "lint:typeaware": "pnpm build:moon-runtime && vp lint . --type-aware --type-check",
    "lint:typeaware:built": "vp lint . --type-aware --type-check",
    "lint:fix": "vp lint . --fix",
    "typecheck": "pnpm build && vp lint . --type-aware --type-check",
    "typecheck:built": "vp lint . --type-aware --type-check",
    "test": "pnpm build && vp test",
    "test:built": "vp test"
  },
  "dependencies": {
    "@shina1024/jqx-adapter-core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.9.3"
  }
}
