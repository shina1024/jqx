{
  "name": "@shina1024/jqx",
  "version": "0.1.0",
  "description": "npm entrypoint for jqx JS/TS runtime and schema adapters",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shina1024/jqx.git",
    "directory": "ts/jqx"
  },
  "homepage": "https://github.com/shina1024/jqx/tree/main/ts/jqx",
  "bugs": {
    "url": "https://github.com/shina1024/jqx/issues"
  },
  "keywords": [
    "jq",
    "json",
    "filter",
    "query",
    "typescript",
    "schema"
  ],
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bind": {
      "types": "./dist/bind.d.ts",
      "import": "./dist/bind.js",
      "require": "./dist/bind.cjs"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.js",
      "require": "./dist/zod.cjs"
    },
    "./yup": {
      "types": "./dist/yup.d.ts",
      "import": "./dist/yup.js",
      "require": "./dist/yup.cjs"
    },
    "./valibot": {
      "types": "./dist/valibot.d.ts",
      "import": "./dist/valibot.js",
      "require": "./dist/valibot.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:moon-runtime": "moon build --target js --release --manifest-path ../../moon.mod.json ../../js",
    "build": "pnpm build:moon-runtime && tsup src/index.ts src/bind.ts src/zod.ts src/yup.ts src/valibot.ts --format esm,cjs --dts --clean",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "pnpm build:moon-runtime && tsc -p tsconfig.json --noEmit",
    "test": "pnpm build:moon-runtime && node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@shina1024/jqx-adapter-core": "^0.1.0",
    "@shina1024/jqx-valibot-adapter": "^0.1.0",
    "@shina1024/jqx-yup-adapter": "^0.1.0",
    "@shina1024/jqx-zod-adapter": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "expect-type": "^1.3.0",
    "oxfmt": "^0.39.0",
    "oxlint": "^1.54.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@shina1024/jqx-adapter-core": "file:../adapter-core",
      "@shina1024/jqx-valibot-adapter": "file:../valibot-adapter",
      "@shina1024/jqx-yup-adapter": "file:../yup-adapter",
      "@shina1024/jqx-zod-adapter": "file:../zod-adapter"
    }
  }
}
